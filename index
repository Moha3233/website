        let simNotes = [
            { id: 1, text: "Peach theme default configuration:\n--tm-window-bg: #fff5f5\n--tm-accent: #d84315", bg: "#fbcfe8", textClass: "text-slate-950", font: "font-fira" },
            { id: 2, text: "Remember to call filesystem access updates natively during auto-backups on computer folders!", bg: "#fef08a", textClass: "text-slate-950", font: "font-handwritten" }
        ];

        // Timeline management parameters
        let timelineBaseDate = 8; // represents Monday of the week (June 8, 2026)
        let activeSelectedDate = 8; // June 8, 2026
        let currentSimTheme = 'peach';
        let currentSimTab = 'calendar';
        let currentSimFilter = 'all';

        let activeNoteColor = '#fef08a';
        let activeNoteFont = 'font-handwritten';
        let splitPanelActive = false;

        // Initialize Web Elements
        document.addEventListener('DOMContentLoaded', () => {
            // Mobile Menu toggle
            const menuBtn = document.getElementById('mobile-menu-btn');
            const menuPanel = document.getElementById('mobile-menu');
            if (menuBtn && menuPanel) {
                menuBtn.addEventListener('click', () => {
                    menuPanel.classList.toggle('hidden');
                });
            }

            // Scroll navbar state
            const navbar = document.getElementById('navbar');
            window.addEventListener('scroll', () => {
                if (window.scrollY > 20) {
                    navbar.classList.add('shadow-xl', 'bg-[#030712]/95', 'border-b', 'border-zinc-900');
                    navbar.classList.remove('glass-panel');
                } else {
                    navbar.classList.remove('shadow-xl', 'bg-[#030712]/95', 'border-b', 'border-zinc-900');
                    navbar.classList.add('glass-panel');
                }
            });

            // Reveal scroll triggers
            const revealElements = document.querySelectorAll('.reveal');
            const revealObserver = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.1, rootMargin: "0px 0px -40px 0px" });

            revealElements.forEach(el => revealObserver.observe(el));

            // Set Initial Simulator layout
            renderTimelineStrip();
            renderSimAgenda();
            renderSimTasks();
            renderSimNotes();
            setSimTheme('peach');
        });

        // --- SIMULATED APP ACTIONS & TOASTS ---
        function triggerSandboxToast(message, type = 'info') {
            const container = document.getElementById('sim-toast-container');
            if (!container) return;

            const toast = document.createElement('div');
            toast.className = `p-3 rounded-lg shadow-lg border text-xs font-semibold flex items-center gap-2.5 transition-all transform translate-y-2 opacity-0 bg-[#090d16] border-zinc-800 text-white z-50`;
            
            let icon = '<i class="ph ph-info text-blue-400 text-base"></i>';
            if (type === 'success') {
                icon = '<i class="ph ph-check-circle text-emerald-400 text-base"></i>';
                toast.classList.add('border-emerald-500/20', 'bg-emerald-950/20');
            } else if (type === 'warning') {
                icon = '<i class="ph ph-warning-circle text-amber-400 text-base"></i>';
                toast.classList.add('border-amber-500/20', 'bg-amber-950/20');
            }

            toast.innerHTML = `${icon} <span>${message}</span>`;
            container.appendChild(toast);

            setTimeout(() => {
                toast.classList.remove('translate-y-2', 'opacity-0');
            }, 50);

            setTimeout(() => {
                toast.classList.add('opacity-0', 'translate-y-[-4px]');
                setTimeout(() => toast.remove(), 300);
            }, 3500);
        }

        // --- SIMULATOR TAB CONTROLS ---
        function switchSimTab(tab) {
            currentSimTab = tab;
            
            // Toggle view panels
            document.getElementById('sim-tab-calendar').classList.add('hidden');
            document.getElementById('sim-tab-tasks').classList.add('hidden');
            document.getElementById('sim-tab-notes').classList.add('hidden');
            
            document.getElementById(`sim-tab-${tab}`).classList.remove('hidden');

            // Toggle Pill background classes inside #tabs-pills-bar mimicking screenshot peach theme styles
            const pillsBar = document.getElementById('tabs-pills-bar');
            const btns = pillsBar.querySelectorAll('button');
            btns.forEach(btn => {
                btn.className = "py-1.5 rounded-lg transition-all tm-sim-muted hover:opacity-85";
                btn.style.backgroundColor = "transparent";
            });

            const activeBtn = document.getElementById(`tab-btn-${tab}`);
            if (activeBtn) {
                activeBtn.className = "py-1.5 rounded-lg transition-all shadow-sm tm-sim-text font-bold";
                activeBtn.style.backgroundColor = "var(--tm-active-tab)";
            }

            triggerSandboxToast(`Switched view: ${tab.toUpperCase()}`, 'info');
        }

        // --- THEME ADAPTATION ---
        function setSimTheme(themeName) {
            currentSimTheme = themeName;
            const root = document.getElementById('sim-body-root');
            if (!root) return;

            // Shift dynamic custom palette variables
            root.className = "flex-1 flex flex-col overflow-hidden text-sm";
            root.classList.add(`tm-theme-${themeName}`);
            root.classList.add(`tm-sim-window`);

            triggerSandboxToast(`Loaded ${themeName.toUpperCase()} color system`, 'success');
        }

        // --- WEEKLY TIMELINE STRIP GENERATOR ---
        function renderTimelineStrip() {
            const container = document.getElementById('sim-weekly-strip-container');
            if (!container) return;

            container.innerHTML = '';
            const weekdays = ['M', 'T', 'W', 'T', 'F', 'S', 'S'];

            for (let i = 0; i < 7; i++) {
                const dayNum = timelineBaseDate + i;
                const weekdayLetter = weekdays[i];
                const isSelected = (dayNum === activeSelectedDate);

                // Check if this day has tasks registered
                const hasTasksOnDay = simTasks.some(t => t.date === dayNum && t.month === 6 && t.year === 2026);

                const itemBtn = document.createElement('button');
                itemBtn.type = 'button';
                itemBtn.onclick = () => selectTimelineDay(dayNum);

                if (isSelected) {
                    itemBtn.className = "p-1.5 rounded-lg text-white font-bold text-center block transition-all shadow-sm relative";
                    itemBtn.style.backgroundColor = "var(--tm-accent)";
                } else {
                    itemBtn.className = "p-1.5 rounded-lg hover:bg-slate-500/10 text-center block transition-all tm-sim-text relative";
                }

                itemBtn.innerHTML = `
                    <span class="block text-[9px] uppercase opacity-75">${weekdayLetter}</span>
                    <span class="text-xs font-extrabold font-outfit block">${dayNum}</span>
                    ${hasTasksOnDay && !isSelected ? '<span class="absolute bottom-1 left-1/2 -translate-x-1/2 w-1 h-1 rounded-full" style="background-color: var(--tm-accent);"></span>' : ''}
                `;
                container.appendChild(itemBtn);
            }

            // Sync top header dates
            document.getElementById('sim-month-header-label').textContent = `June 2026`;
            updateCompletionCounts();
        }

        function selectTimelineDay(dayNum) {
            activeSelectedDate = dayNum;
            renderTimelineStrip();
            renderSimAgenda();
        }

        function shiftTimeline(amount) {
            timelineBaseDate += amount;
            if (timelineBaseDate < 1) timelineBaseDate = 1;
            if (timelineBaseDate > 24) timelineBaseDate = 24; // limit bounds for mock preview simplicity
            
            // Adjust selection as well
            activeSelectedDate = timelineBaseDate;
            renderTimelineStrip();
            renderSimAgenda();
            triggerSandboxToast(`Shifted schedule timeline`, 'info');
        }

        function resetTimelineToday() {
            timelineBaseDate = 8;
            activeSelectedDate = 8;
            renderTimelineStrip();
            renderSimAgenda();
            triggerSandboxToast(`Reset to June 8, 2026 (Today)`, 'success');
        }

        // --- AGENDA MANAGEMENT ---
        function renderSimAgenda() {
            const dateLabel = document.getElementById('sim-cal-agenda-date');
            const countLabel = document.getElementById('sim-cal-agenda-count');
            const container = document.getElementById('sim-agenda-items-list');
            if (!dateLabel || !countLabel || !container) return;

            dateLabel.textContent = `June ${activeSelectedDate}, 2026`;
            
            const daysTasks = simTasks.filter(t => t.date === activeSelectedDate && t.month === 6 && t.year === 2026);
            countLabel.textContent = `${daysTasks.length} task${daysTasks.length === 1 ? '' : 's'} active`;

            container.innerHTML = '';

            if (daysTasks.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-10 select-none">
                        <!-- Screen-accurate list empty state layout -->
                        <div class="inline-flex items-center justify-center w-10 h-10 rounded-xl mb-3" style="background-color: var(--tm-tab-bg); color: var(--tm-accent)">
                            <i class="ph ph-list-checks text-xl"></i>
                        </div>
                        <p class="text-xs font-semibold tm-sim-muted">No tasks for this date.</p>
                    </div>`;
                return;
            }

            daysTasks.forEach(task => {
                const card = document.createElement('div');
                card.className = `p-3 rounded-lg border flex items-center justify-between gap-3 transition-all tm-sim-card ${task.completed ? 'opacity-65' : ''}`;
                card.style.borderLeft = `3px solid ${task.priority === 'High' ? '#ef4444' : task.priority === 'Medium' ? '#f59e0b' : '#14b8a6'}`;

                const completeIcon = task.completed ? 'ph-fill ph-check-circle text-emerald-500' : 'ph ph-circle tm-sim-muted';
                const referenceLink = task.link ? `<a href="${task.link}" target="_blank" class="text-[9px] mt-1 hover:underline inline-flex items-center gap-0.5" style="color: var(--tm-accent)">🔗 URL Link</a>` : '';

                card.innerHTML = `
                    <div class="flex items-center gap-3 overflow-hidden">
                        <button onclick="toggleTaskCompletion(${task.id})" class="text-base focus:outline-none shrink-0">
                            <i class="${completeIcon}"></i>
                        </button>
                        <div class="overflow-hidden">
                            <span class="block text-xs font-bold tm-sim-text ${task.completed ? 'line-through opacity-70' : ''}">${task.text}</span>
                            ${referenceLink}
                        </div>
                    </div>
                    <div class="flex items-center gap-1.5 shrink-0">
                        <span class="text-[8px] font-bold px-1.5 py-0.5 rounded uppercase ${task.priority === 'High' ? 'bg-red-400/20 text-red-500' : task.priority === 'Medium' ? 'bg-yellow-400/20 text-yellow-600' : 'bg-teal-400/20 text-teal-600'}">${task.priority}</span>
                        <button onclick="deleteTask(${task.id})" class="text-slate-400 hover:text-red-500 text-sm">
                            <i class="ph ph-trash"></i>
                        </button>
                    </div>
                `;
                container.appendChild(card);
            });

            updateCompletionCounts();
        }

        // --- CUMULATIVE ALL TASKS RENDERING ---
        function renderSimTasks() {
            const container = document.getElementById('sim-all-tasks-list');
            if (!container) return;

            let filtered = simTasks;
            if (currentSimFilter === 'pending') filtered = simTasks.filter(t => !t.completed);
            if (currentSimFilter === 'completed') filtered = simTasks.filter(t => t.completed);

            document.getElementById('sim-total-count-lbl').textContent = filtered.length;
            container.innerHTML = '';

            if (filtered.length === 0) {
                container.innerHTML = `<p class="text-xs text-center py-6 tm-sim-muted">No entries registered under current scope.</p>`;
                return;
            }

            filtered.forEach(task => {
                const card = document.createElement('div');
                card.className = `p-3 rounded-lg border flex items-center justify-between gap-3 transition-all tm-sim-card ${task.completed ? 'opacity-65' : ''}`;
                card.style.borderLeft = `3px solid ${task.priority === 'High' ? '#ef4444' : task.priority === 'Medium' ? '#f59e0b' : '#14b8a6'}`;

                const completeIcon = task.completed ? 'ph-fill ph-check-circle text-emerald-500' : 'ph ph-circle tm-sim-muted';

                card.innerHTML = `
                    <div class="flex items-center gap-3 overflow-hidden">
                        <button onclick="toggleTaskCompletion(${task.id})" class="text-base shrink-0">
                            <i class="${completeIcon}"></i>
                        </button>
                        <div class="overflow-hidden">
                            <span class="block text-xs font-bold tm-sim-text ${task.completed ? 'line-through opacity-70' : ''}">${task.text}</span>
                            <span class="text-[9px] tm-sim-muted">Due: June ${task.date}, 2026</span>
                        </div>
                    </div>
                    <div class="flex items-center gap-1.5 shrink-0">
                        <button onclick="deleteTask(${task.id})" class="text-slate-400 hover:text-red-500 text-sm">
                            <i class="ph ph-trash"></i>
                        </button>
                    </div>
                `;
                container.appendChild(card);
            });
        }

        function toggleAddTaskForm() {
            const form = document.getElementById('sim-inline-task-form');
            form.classList.toggle('hidden');
        }

        function saveInlineTask() {
            const textInput = document.getElementById('inline-task-text');
            const priorityInput = document.getElementById('inline-task-priority');
            const linkInput = document.getElementById('inline-task-link');

            if (!textInput.value.trim()) {
                triggerSandboxToast('Please describe the task objective!', 'warning');
                return;
            }

            const newTask = {
                id: Date.now(),
                text: textInput.value,
                priority: priorityInput.value,
                date: activeSelectedDate,
                month: 6,
                year: 2026,
                completed: false,
                link: linkInput.value.trim()
            };

            simTasks.unshift(newTask);
            
            // clear inputs
            textInput.value = '';
            linkInput.value = '';
            toggleAddTaskForm();

            renderTimelineStrip();
            renderSimAgenda();
            renderSimTasks();
            triggerSandboxToast('Saved task to agenda collection!', 'success');
        }

        function toggleTaskCompletion(id) {
            const task = simTasks.find(t => t.id === id);
            if (task) {
                task.completed = !task.completed;
                renderTimelineStrip();
                renderSimAgenda();
                renderSimTasks();
                triggerSandboxToast(`Item marked as ${task.completed ? 'Finished' : 'Pending'}`, 'success');
            }
        }

        function deleteTask(id) {
            simTasks = simTasks.filter(t => t.id !== id);
            renderTimelineStrip();
            renderSimAgenda();
            renderSimTasks();
            triggerSandboxToast('Item deleted successfully', 'warning');
        }

        function filterSimTasks(scope) {
            currentSimFilter = scope;
            
            document.getElementById('filter-btn-all').className = "tm-sim-muted hover:text-white";
            document.getElementById('filter-btn-pending').className = "tm-sim-muted hover:text-white";
            document.getElementById('filter-btn-completed').className = "tm-sim-muted hover:text-white";

            document.getElementById(`filter-btn-${scope}`).className = "font-bold tm-sim-accent";
            renderSimTasks();
        }

        function updateCompletionCounts() {
            const completionBadge = document.getElementById('sim-completion-badge');
            if (!completionBadge) return;

            const totalCount = simTasks.length;
            const completedCount = simTasks.filter(t => t.completed).length;
            completionBadge.textContent = `Done: ${completedCount}/${totalCount}`;
        }

        // --- STICKY NOTES ACTIONS ---
        function renderSimNotes() {
            const grid = document.getElementById('sim-notes-grid');
            if (!grid) return;

            grid.innerHTML = '';
            simNotes.forEach(note => {
                const card = document.createElement('div');
                card.className = `${note.bg} p-3 rounded-xl text-slate-900 shadow border border-black/5 flex flex-col justify-between h-28 transform rotate-1 hover:rotate-0 transition-all ${note.font}`;
                card.style.backgroundColor = note.bg;

                card.innerHTML = `
                    <p class="text-xs font-semibold whitespace-pre-wrap overflow-y-auto leading-relaxed max-h-[80px]">${note.text}</p>
                    <div class="flex items-center justify-between border-t border-black/5 pt-1.5 mt-1">
                        <span class="text-[8px] tracking-widest font-bold font-sans uppercase text-slate-500">TaskMaster Scratchpad</span>
                        <button onclick="deleteSimNote(${note.id})" class="text-slate-500 hover:text-red-600">
                            <i class="ph ph-trash text-xs"></i>
                        </button>
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        function setSimNoteColor(hex) {
            activeNoteColor = hex;
            triggerSandboxToast('Background swatch updated', 'info');
        }

        function setSimNoteFont(fontClass) {
            activeNoteFont = fontClass;
            triggerSandboxToast(`Font selection: ${fontClass.replace('font-', '').toUpperCase()}`, 'info');
        }

        function addSimNote() {
            const textarea = document.getElementById('sim-note-textarea');
            if (!textarea.value.trim()) {
                triggerSandboxToast('Please write content inside your scratch note!', 'warning');
                return;
            }

            const newNote = {
                id: Date.now(),
                text: textarea.value,
                bg: activeNoteColor,
                font: activeNoteFont
            };

            simNotes.unshift(newNote);
            textarea.value = '';
            renderSimNotes();
            triggerSandboxToast('Note posted to theme board!', 'success');
        }

        function deleteSimNote(id) {
            simNotes = simNotes.filter(n => n.id !== id);
            renderSimNotes();
            triggerSandboxToast('Sticky note discarded', 'warning');
        }

        function toggleSimSplitPanel() {
            splitPanelActive = !splitPanelActive;
            triggerSandboxToast(splitPanelActive ? 'Sidebar split view enabled' : 'Focused layout enabled', 'info');
        }

        function simBackupSimulation() {
            triggerSandboxToast('Connecting local secure folder path...', 'info');
            setTimeout(() => {
                triggerSandboxToast('Automated backup processed successfully! Generated: "taskmaster_backup.json"', 'success');
            }, 800);
        }

        function simExportJSON() {
            const dataStr = JSON.stringify({ app: "TaskMaster 2.0", tasks: simTasks, notes: simNotes }, null, 2);
            const tempTextarea = document.createElement('textarea');
            tempTextarea.value = dataStr;
            document.body.appendChild(tempTextarea);
            tempTextarea.select();
            document.execCommand('copy');
            document.body.removeChild(tempTextarea);

            triggerSandboxToast('JSON data exported & copied to clipboard!', 'success');
        }

        function simImportPrompt() {
            triggerSandboxToast('Simulation: Select backup file prompt triggered successfully', 'info');
        }

        function simAddPresetTask() {
            simTasks = [
                { id: 101, text: "Finish final figma design systems updates", priority: "High", date: 8, month: 6, year: 2026, completed: false, link: "https://figma.com" },
                { id: 102, text: "Double-check Dracula palette colors in chrome manifest", priority: "Medium", date: 8, month: 6, year: 2026, completed: false, link: "" },
                { id: 103, text: "Organize launch criterion benchmarks", priority: "High", date: 9, month: 6, year: 2026, completed: false, link: "" },
                { id: 104, text: "Draft comprehensive user manual guides", priority: "Low", date: 11, month: 6, year: 2026, completed: true, link: "" }
            ];
            renderTimelineStrip();
            renderSimAgenda();
            renderSimTasks();
            triggerSandboxToast('Imported mock presets to timeline database!', 'success');
        }

        // --- LANDING PAGE CUSTOM FAQ ACCORDIONS ---
        function toggleFaq(id) {
            const answer = document.getElementById(`faq-ans-${id}`);
            const icon = document.getElementById(`faq-icon-${id}`);
            
            if (answer.classList.contains('open')) {
                answer.classList.remove('open');
                icon.className = "ph ph-plus text-zinc-400 text-base transition-transform duration-300";
            } else {
                for (let i = 1; i <= 3; i++) {
                    const ans = document.getElementById(`faq-ans-${i}`);
                    const ic = document.getElementById(`faq-icon-${i}`);
                    if (ans && ic) {
                        ans.classList.remove('open');
                        ic.className = "ph ph-plus text-zinc-400 text-base transition-transform duration-300";
                    }
                }
                
                answer.classList.add('open');
                icon.className = "ph ph-minus text-white text-base transition-transform duration-300";
            }
        }

        function handleContactSubmit(event) {
            event.preventDefault();
            const form = event.target;
            triggerSandboxToast('Message submitted securely to BrahmaVivek Labs!', 'success');
            form.reset();
        }
    </script>
</body>
</html>
